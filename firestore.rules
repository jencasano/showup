rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // USERS
    // Anyone logged in can read all user profiles
    // Only you can write your own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // LOGS
    // Anyone logged in can read all logs
    // Only you can write your own log entry
    match /logs/{yearMonth}/entries/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // DIARY
    // Any logged-in user can read diary entries (privacy enforced client-side)
    // Only you can write your own diary entries
    match /diary/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      match /entries/{entryId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ENTITLEMENTS
    // Only the user can read their own entitlements.
    // Clients can CREATE their own initial entitlements doc (signup seed)
    // but cannot update or delete. Future paid-cover purchases will be
    // written by a Cloud Function with admin rights.
    match /entitlements/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if false;
    }

  }
}
